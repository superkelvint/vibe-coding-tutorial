---
import { getCollection } from 'astro:content';
import CourseLayout from '../layouts/CourseLayout.astro';
const lessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);
---
<CourseLayout>
  <section class="home-hero"><p class="eyebrow">A guided MDX workbook</p><h1>Vibe Coding Foundations</h1><p class="lede">Build a reliable mental map of webapps—and a reliable way to work with Codex without surrendering judgment.</p></section>
  <section class="home-section" aria-labelledby="course-map"><p class="eyebrow">Course map</p><h2 id="course-map">Start small. Check your work. Explain what changed.</h2><div class="lesson-list">{lessons.map((lesson) => <a class="lesson-card" href={`${import.meta.env.BASE_URL}lessons/${lesson.id}/`}><span class="lesson-number">{String(lesson.data.order).padStart(2, '0')}</span><span><strong>{lesson.data.title}</strong><small>{lesson.data.section} · {lesson.data.estimatedTime}</small></span><span aria-hidden="true">→</span></a>)}</div></section>
</CourseLayout>
