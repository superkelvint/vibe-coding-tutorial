<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="model-purpose" aria-live="polite">
  <p><strong>Approximate network location</strong></p>
  <p id="freeipapi-status">Asking IPify for an IP address, then FreeIPAPI for broad location information…</p>
  <p id="freeipapi-location" class="live-location">Waiting for both API responses.</p>
  <div id="freeipapi-map" class="live-map" aria-label="Map showing the approximate network location" hidden></div>
  <details>
    <summary>See the FreeIPAPI JSON response</summary>
    <pre class="astro-code" data-language="json"><code id="freeipapi-json">Waiting for JSON…</code></pre>
  </details>
</div>

<script>
  const locationStatus = document.querySelector<HTMLElement>('#freeipapi-status');
  const locationOutput = document.querySelector<HTMLElement>('#freeipapi-location');
  const locationJson = document.querySelector<HTMLElement>('#freeipapi-json');
  const mapElement = document.querySelector<HTMLElement>('#freeipapi-map');

  if (!locationStatus || !locationOutput || !locationJson || !mapElement) {
    throw new Error('The FreeIPAPI display elements are missing from the page');
  }

  const leafletWindow = window as Window & { L?: any };

  function loadLeaflet() {
    if (leafletWindow.L) {
      return Promise.resolve(leafletWindow.L);
    }

    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.onload = () => resolve(leafletWindow.L);
      script.onerror = () => reject(new Error('The map library could not be loaded'));
      document.head.appendChild(script);
    });
  }

  async function showMap(latitude: number, longitude: number) {
    const L = await loadLeaflet();
    mapElement!.hidden = false;
    const map = L.map(mapElement).setView([latitude, longitude], 3);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);

    L.marker([latitude, longitude])
      .addTo(map)
      .bindPopup('Approximate network location')
      .openPopup();

    window.setTimeout(() => map.invalidateSize(), 0);
  }

  fetch('https://api64.ipify.org?format=json')
    .then((response) => {
      if (!response.ok) {
        throw new Error(`The IPify request failed with status ${response.status}`);
      }
      return response.json();
    })
    .then(async (ipData) => {
      if (!ipData.ip) {
        throw new Error('The IPify response did not contain an ip value');
      }

      const response = await fetch(
        `https://free.freeipapi.com/api/json/${encodeURIComponent(ipData.ip)}`
      );
      if (!response.ok) {
        throw new Error(`FreeIPAPI responded with status ${response.status}`);
      }

      const location = await response.json();
      if (!location.countryName) {
        throw new Error('The FreeIPAPI response did not contain a country');
      }

      locationJson.textContent = JSON.stringify(location, null, 2);
      locationOutput.textContent =
        `Approximate network location: ${location.cityName || 'Unknown city'}, ${location.regionName || 'Unknown region'}, ${location.countryName}`;
      locationStatus.textContent = 'Both APIs answered. The page used the first response to make the second request.';

      if (typeof location.latitude === 'number' && typeof location.longitude === 'number') {
        try {
          await showMap(location.latitude, location.longitude);
        } catch (mapError) {
          const message = mapError instanceof Error ? mapError.message : 'the map could not be loaded';
          locationStatus.textContent += ` The location text loaded, but ${message}.`;
        }
      }
    })
    .catch((error) => {
      const message = error instanceof Error ? error.message : 'the location request failed';
      locationStatus.textContent = `The location lookup failed: ${message}`;
      locationOutput.textContent = 'No approximate location is available.';
      locationJson.textContent = 'No JSON response was available.';
    });
</script>
